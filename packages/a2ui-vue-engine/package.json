{
  "name": "a2ui-vue-engine",
  "version": "1.0.8",
  "description": "A2UI Vue3 Render Engine - JSON Schema driven UI rendering for Vue3 applications",
  "type": "module",
  "main": "./dist/a2ui-vue-engine.umd.cjs",
  "module": "./dist/a2ui-vue-engine.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/a2ui-vue-engine.js",
      "require": "./dist/a2ui-vue-engine.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css",
    "./styles": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "keywords": [
    "a2ui",
    "vue3",
    "render-engine",
    "json-schema",
    "ui-library",
    "element-plus",
    "dynamic-ui"
  ],
  "author": "A2UI Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chenhui9392/a2ui-vue-engine.git"
  },
  "homepage": "https://chenhui9392.github.io/a2ui-vue-engine/",
  "bugs": {
    "url": "https://github.com/chenhui9392/a2ui-vue-engine/issues"
  },
  "peerDependencies": {
    "vue": "^3.4.0",
    "element-plus": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "element-plus": "^2.5.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
